args <- commandArgs(trailingOnly = TRUE)
target_date <- if (length(args) >= 1) args[1] else NULL
log_dir <- Sys.getenv("PMS_LOG_DIR", "/home/rachel/Documents/snicken_luft/pms_logs")
out_dir <- Sys.getenv("PMS_NODE_OUT_DIR", "~/pms_reports/nodes")
log_dir <- path.expand(log_dir)
out_dir <- path.expand(out_dir)
if (!dir.exists(log_dir)) {
stop(paste("Log directory not found:", log_dir))
}
if (!dir.exists(out_dir)) {
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)
}
pattern <- if (!is.null(target_date)) {
paste0("__", target_date, "\\.csv$")
} else {
"__\\d{4}-\\d{2}-\\d{2}\\.csv$"
}
files <- list.files(log_dir, pattern = pattern, full.names = TRUE)
if (length(files) == 0) {
msg <- if (!is.null(target_date)) {
paste("No files found for", target_date)
} else {
"No files found"
}
message(msg)
quit(status = 0)
}
parse_topic <- function(safe_topic) {
m <- regexec("^sensors_pms5003_(node-[^_]+)_sensor_(.*)_state$", safe_topic)
parts <- regmatches(safe_topic, m)[[1]]
if (length(parts) >= 3) {
return(list(node = parts[2], metric = parts[3]))
}
return(list(node = NA, metric = NA))
}
node_tables <- list()
for (f in files) {
df <- read.csv(f, stringsAsFactors = FALSE)
if (!all(c("epoch", "value") %in% names(df))) {
if (ncol(df) >= 2) {
names(df)[1:2] <- c("epoch", "value")
}
}
df$epoch <- suppressWarnings(as.numeric(df$epoch))
df$value <- suppressWarnings(as.numeric(df$value))
df <- df[is.finite(df$epoch) & is.finite(df$value), ]
if (nrow(df) == 0) {
next
}
base <- basename(f)
date_tag <- sub(".*__(\\d{4}-\\d{2}-\\d{2})\\.csv$", "\\1", base)
safe_topic <- sub("__\\d{4}-\\d{2}-\\d{2}\\.csv$", "", base)
meta <- parse_topic(safe_topic)
if (is.na(meta$node) || is.na(meta$metric)) {
next
}
out <- data.frame(
date = date_tag,
epoch = df$epoch,
value = df$value,
metric = meta$metric,
topic = safe_topic,
stringsAsFactors = FALSE
)
if (is.null(node_tables[[meta$node]])) {
node_tables[[meta$node]] <- out
} else {
node_tables[[meta$node]] <- rbind(node_tables[[meta$node]], out)
}
}
if (length(node_tables) == 0) {
message("No usable data rows found")
quit(status = 0)
}
for (node in names(node_tables)) {
node_df <- node_tables[[node]]
node_df <- node_df[order(node_df$epoch), ]
name_tag <- if (!is.null(target_date)) {
paste0("pms_", node, "__", target_date, ".csv")
} else {
paste0("pms_", node, "__all.csv")
}
out_file <- file.path(out_dir, name_tag)
write.csv(node_df, out_file, row.names = FALSE)
message(paste("Wrote:", out_file))
}
node_tables %>% glimpse
node_tables %>% glimpse
node_df %>% list_rbind(names_to = node)
node_df %>% list_rbind(names_to = "node")
node_df %>% list_rbind()
node_tables %>% list_rbind(names_to = "node")
node_tables %>% list_rbind(names_to = "node") %>% glimpse
